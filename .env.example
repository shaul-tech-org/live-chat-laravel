APP_NAME="Live Chat"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lchat.example.com

# ===========================
# Database — PostgreSQL 18
# ===========================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=live_chat
DB_USERNAME=chatuser
DB_PASSWORD=changeme

# ===========================
# MongoDB 8
# ===========================
MONGODB_URI=mongodb://chatuser:changeme@mongodb:27017
MONGODB_DATABASE=live_chat

# ===========================
# Redis 8
# ===========================
REDIS_HOST=redis
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# ===========================
# Broadcasting — Laravel Reverb
# ===========================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=live-chat
REVERB_APP_KEY=live-chat-key
REVERB_APP_SECRET=live-chat-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080

# ===========================
# Admin Authentication
# ===========================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Keycloak (optional)
# AUTH_API_URL=http://auth-api:10411

# ===========================
# Telegram Bot (optional)
# ===========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ===========================
# Widget
# ===========================
WIDGET_DOMAIN=https://lchat.example.com

# ===========================
# Monitoring (optional)
# ===========================
# ENABLE_METRICS=true

# ===========================
# File Storage
# ===========================
FILESYSTEM_DISK=local
# For S3/MinIO:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=changeme
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=chat
# AWS_ENDPOINT=http://minio:9000
# AWS_USE_PATH_STYLE_ENDPOINT=true
