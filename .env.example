APP_NAME="Live Chat"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lchat.example.com
APP_PORT=80

# ===========================
# Database — PostgreSQL 18
# ===========================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=live_chat
DB_USERNAME=chatuser
DB_PASSWORD=changeme

# ===========================
# MongoDB 8
# ===========================
MONGO_USERNAME=chatuser
MONGO_PASSWORD=changeme
MONGODB_URI=mongodb://${MONGO_USERNAME}:${MONGO_PASSWORD}@mongodb:27017
MONGODB_DATABASE=live_chat

# ===========================
# Redis 8
# ===========================
REDIS_HOST=redis
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# ===========================
# Broadcasting — Laravel Reverb
# ===========================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=live-chat
REVERB_APP_KEY=live-chat-key
REVERB_APP_SECRET=live-chat-secret
# Reverb 서버 바인딩 (내부)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Reverb 클라이언트 접속 (외부)
REVERB_HOST=lchat.example.com
REVERB_PORT=443
REVERB_SCHEME=https
# Vite/Echo.js 클라이언트 설정
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=lchat.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ===========================
# Queue / Cache / Session
# ===========================
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ===========================
# Admin Authentication
# ===========================
# Option 1: Built-in (self-hosted, Keycloak 불필요)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Option 2: Keycloak (optional)
# AUTH_API_URL=http://auth-api:10411

# ===========================
# Telegram Bot (optional)
# ===========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ===========================
# Widget
# ===========================
WIDGET_DOMAIN=https://lchat.example.com

# ===========================
# Monitoring (optional)
# ===========================
# ENABLE_METRICS=true

# ===========================
# File Storage
# ===========================
FILESYSTEM_DISK=local
# For S3/MinIO (optional):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=changeme
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=chat
# AWS_ENDPOINT=http://minio:9000
# AWS_USE_PATH_STYLE_ENDPOINT=true

# ===========================
# Mail (트랜스크립트 이메일)
# ===========================
# 개발환경: log (메일 전송 대신 로그에 기록)
# 운영환경: smtp (실제 SMTP 서버 사용)
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Live Chat"

# ===========================
# Logging
# ===========================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info
LOG_DAILY_DAYS=14

# ===========================
# Docker Compose 포트 매핑 (호스트 포트)
# ===========================
# APP_PORT=80                    # nginx 외부 포트
# PG_PORT=5432                   # PostgreSQL 외부 포트
# MONGO_EXTERNAL_PORT=27017      # MongoDB 외부 포트
# REDIS_EXTERNAL_PORT=6379       # Redis 외부 포트
